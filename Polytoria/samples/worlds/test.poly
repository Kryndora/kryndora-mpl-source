      </Properties>
      <Item class="ScriptInstance">
        <Properties>
          <string name="Source">local co = coroutine.create(function()
    local Brick = script.Parent

    print("Brick: ", Brick)
    print("Brick.Touched: ", Brick.Touched)
    print("Brick.Touched:Connect: ", Brick.Touched.Connect)
    print("Brick.GetChildren: ", Brick.GetChildren)
    print("child count: ", #Brick:GetChildren())
    Brick.Touched:Connect(function(hit)
        print("Touched!")
        if hit.ClassName == "Player" then
            hit.Health = 0
        end
    end)
end)

local status, result = coroutine.resume(co)</string>
          <string name="Name">ScriptInstance</string>
        </Properties>
      </Item>
    </Item>
